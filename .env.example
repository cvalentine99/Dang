# ============================================================================
# Dang! SIEM — Environment Configuration
# Copy this file to .env and fill in your values:  cp .env.example .env
# Or use the Docker template:  cp env.docker.template .env
# ============================================================================
#
# See env.docker.template for full documentation of all settings.
# This file contains the minimum required variables.
#
# WARNING: Use LITERAL values only. Do NOT use shell expansion syntax.

# ── MySQL Database ───────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=dang
MYSQL_USER=dang
MYSQL_PASSWORD=change_me_db_password
DATABASE_URL=mysql://dang:change_me_db_password@localhost:3306/dang

# ── Authentication ───────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# ── Wazuh Manager API (REQUIRED) ────────────────────────────────────────────
WAZUH_HOST=localhost
WAZUH_PORT=55000
WAZUH_USER=wazuh-wui
WAZUH_PASS=CHANGE_ME

# ── Wazuh Indexer / OpenSearch (REQUIRED) ────────────────────────────────────
WAZUH_INDEXER_HOST=localhost
WAZUH_INDEXER_PORT=9200
WAZUH_INDEXER_USER=admin
WAZUH_INDEXER_PASS=CHANGE_ME
WAZUH_INDEXER_PROTOCOL=https

# ── TLS ──────────────────────────────────────────────────────────────────────
SKIP_TLS_VERIFY=true

# ── Optional: AlienVault OTX ─────────────────────────────────────────────────
OTX_API_KEY=

# ── Optional: Splunk ─────────────────────────────────────────────────────────
SPLUNK_HOST=
SPLUNK_PORT=8089
SPLUNK_HEC_PORT=8088
SPLUNK_HEC_TOKEN=

# ── Optional: LLM ───────────────────────────────────────────────────────────
LLM_HOST=
LLM_PORT=8080
LLM_MODEL=unsloth/Nemotron-3-Nano-30B-A3B-GGUF
LLM_ENABLED=false

# ── App Branding ─────────────────────────────────────────────────────────────
VITE_APP_TITLE=Dang! SIEM
VITE_APP_LOGO=
